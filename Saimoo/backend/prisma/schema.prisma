generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Activity {
  id          Int
  name        String?  @db.VarChar(45)
  description String?  @db.VarChar(45)
  startDate   DateTime @db.DateTime(0)
  endDate     DateTime @db.DateTime(0)
  image       Bytes?
  templeId    Int
  Temple      Temple   @relation(fields: [templeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_templeActivity_temple1")

  @@id([id, templeId])
  @@index([templeId], map: "fk_templeActivity_temple1_idx")
}

model Charm {
  charmId      Int
  name         String?   @db.VarChar(45)
  price        Float?    @db.Float
  image        Bytes?
  avalibleDate DateTime? @db.DateTime(0)
  status       Int       @default(1) @db.TinyInt
  detail       String?   @db.VarChar(45)
  templeId     Int
  Temple       Temple    @relation(fields: [templeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_templeCharm_temple1")

  @@id([charmId, templeId])
  @@index([templeId], map: "fk_templeCharm_temple1_idx")
}

model IdentityDocument {
  id           Int
  type         IdentityDocument_type
  filePath     String?               @db.VarChar(255)
  UploadedDate DateTime              @default(now()) @db.DateTime(0)
  requestId    Int
  Request      Request               @relation(fields: [requestId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_identityDocument_request1")

  @@id([id, requestId])
  @@index([requestId], map: "fk_identityDocument_request1_idx")
}

model Request {
  id               Int                @default(autoincrement()) @unique
  type             Request_type
  status           Request_status     @default(Pending)
  createdDate      DateTime           @default(now()) @db.DateTime(0)
  userId           Int
  IdentityDocument IdentityDocument[]
  User             User               @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_request_user1")

  @@id([id, userId])
  @@index([userId], map: "fk_request_user1_idx")
}

model ReviewGuide {
  id                             Int      @id @default(autoincrement())
  rating                         Float?   @db.Float
  comment                        String?  @db.Text
  reviewDate                     DateTime @default(now()) @db.DateTime(0)
  userId                         Int
  guideId                        Int
  User_ReviewGuide_userIdToUser  User     @relation("ReviewGuide_userIdToUser", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviewGuide_user1")
  User_ReviewGuide_guideIdToUser User     @relation("ReviewGuide_guideIdToUser", fields: [guideId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviewGuide_user2")

  @@index([userId], map: "fk_reviewGuide_user1_idx")
  @@index([guideId], map: "fk_reviewGuide_user2_idx")
}

model ReviewTrip {
  id         Int
  rating     Float?   @db.Float
  comment    String?  @db.Text
  reviewDate DateTime @default(now()) @db.DateTime(0)
  tripId     Int
  userId     Int
  Trip       Trip     @relation(fields: [tripId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviewTrip_trip1")
  User       User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviewTrip_user1")

  @@id([id, tripId, userId])
  @@index([tripId], map: "fk_reviewTrip_trip1_idx")
  @@index([userId], map: "fk_reviewTrip_user1_idx")
}

model Temple {
  id          Int           @id @default(autoincrement())
  name        String?       @db.VarChar(45)
  description String?       @db.VarChar(45)
  latitude    Float?
  longitude   Float?
  likes       Int?
  Activity    Activity[]
  Charm       Charm[]
  TempleImage TempleImage[]
  TripDetail  TripDetail[]
}

model TempleImage {
  id          Int
  image       Bytes?
  description String? @db.VarChar(45)
  templeId    Int
  Temple      Temple  @relation(fields: [templeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_templeAlbum_temple1")

  @@id([id, templeId])
  @@index([templeId], map: "fk_templeAlbum_temple1_idx")
}

model Tranfer {
  id                                    Int
  from_wallet_id                        Int
  to_wallet_id                          Int
  amount                                Float    @db.Float
  timestamp                             DateTime @default(now()) @db.DateTime(0)
  status                                String   @db.VarChar(45)
  Wallet_Tranfer_from_wallet_idToWallet Wallet   @relation("Tranfer_from_wallet_idToWallet", fields: [from_wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tranfer_wallet1")
  Wallet_Tranfer_to_wallet_idToWallet   Wallet   @relation("Tranfer_to_wallet_idToWallet", fields: [to_wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tranfer_wallet2")

  @@id([id, from_wallet_id, to_wallet_id])
  @@index([from_wallet_id], map: "fk_tranfer_wallet1_idx")
  @@index([to_wallet_id], map: "fk_tranfer_wallet2_idx")
}

model Transaction {
  id        Int
  walletId  Int
  type      Transaction_type
  amount    Float            @db.Float
  timestamp DateTime         @default(now()) @db.DateTime(0)
  status    String           @db.VarChar(45)
  Wallet    Wallet           @relation(fields: [walletId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transaction_wallet1")

  @@id([id, walletId])
  @@index([walletId], map: "fk_transaction_wallet1_idx")
}

model Trip {
  id              Int           @id
  title           String        @db.VarChar(64)
  description     String?       @db.Text
  dateStart       DateTime      @db.DateTime(0)
  dateEnd         DateTime      @db.DateTime(0)
  vehicle         Trip_vehicle?
  price           Float         @db.Float
  maxPerson       Int
  type            Trip_type     @default(post)
  recommendPerson Int?
  status          String        @db.VarChar(45)
  ReviewTrip      ReviewTrip[]
  TripDetail      TripDetail[]
  TripPicture     TripPicture[]
  UserInTrip      UserInTrip[]
}

model TripDetail {
  id                Int                 @id
  tripId            Int
  templeId          Int?
  locationName      String?             @db.VarChar(45)
  order             Int
  arriveTime        DateTime            @db.Time(0)
  day               Int
  description       String?             @db.Text
  Temple            Temple?             @relation(fields: [templeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tripDetail_temple2")
  Trip              Trip                @relation(fields: [tripId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tripDetail_trip2")
  TripDetailPicture TripDetailPicture[]

  @@index([templeId], map: "fk_tripDetail_temple2_idx")
  @@index([tripId], map: "fk_tripDetail_trip2_idx")
}

model TripDetailPicture {
  id           Int        @id
  image        Bytes?
  tripDetailId Int
  TripDetail   TripDetail @relation(fields: [tripDetailId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tripDetailPicture_tripDetail1")

  @@index([tripDetailId], map: "fk_tripDetailPicture_tripDetail1_idx")
}

model TripPicture {
  id     Int    @id
  image  Bytes?
  tripId Int
  Trip   Trip   @relation(fields: [tripId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tripPicture_trip1")

  @@index([tripId], map: "fk_tripPicture_trip1_idx")
}

model User {
  id                                    Int           @id @default(autoincrement())
  username                              String        @unique(map: "username_UNIQUE") @db.VarChar(45)
  email                                 String        @unique(map: "email_UNIQUE") @db.VarChar(45)
  password                              String        @db.VarChar(255)
  fullName                              String?       @db.VarChar(64)
  phone                                 String?       @db.VarChar(45)
  role                                  User_role     @default(user)
  createdAt                             DateTime      @default(now()) @db.DateTime(0)
  updatedAt                             DateTime      @default(now()) @db.DateTime(0)
  Request                               Request[]
  ReviewGuide_ReviewGuide_userIdToUser  ReviewGuide[] @relation("ReviewGuide_userIdToUser")
  ReviewGuide_ReviewGuide_guideIdToUser ReviewGuide[] @relation("ReviewGuide_guideIdToUser")
  ReviewTrip                            ReviewTrip[]
  UserInTrip                            UserInTrip[]
  Wallet                                Wallet[]
}

model UserInTrip {
  userId Int
  tripId Int
  Trip   Trip @relation(fields: [tripId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_userInTrip_trip1")
  User   User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_userInTrip_user1")

  @@id([userId, tripId])
  @@index([tripId], map: "fk_userInTrip_trip1_idx")
  @@index([userId], map: "fk_userInTrip_user1_idx")
}

model Wallet {
  id                                     Int @unique
  balance                                Float         @db.Float
  userId                                 Int
  Tranfer_Tranfer_from_wallet_idToWallet Tranfer[]     @relation("Tranfer_from_wallet_idToWallet")
  Tranfer_Tranfer_to_wallet_idToWallet   Tranfer[]     @relation("Tranfer_to_wallet_idToWallet")
  Transaction                            Transaction[]
  User                                   User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_wallet_user1")

  @@id([id, userId])
  @@index([userId], map: "fk_wallet_user1_idx")
}

enum Request_type {
  Become_Guide       @map("Become Guide")
  Register_as_Temple @map("Register as Temple")
}

enum IdentityDocument_type {
  Id_verification     @map("Id verification")
  Guide_Certification @map("Guide Certification")
  Temple_Document     @map("Temple Document")
}

enum Transaction_type {
  deposit
  withdraw
}

enum Request_status {
  Pending
  Approved
  Rejected
}

enum Trip_vehicle {
  van
  bus
}

enum User_role {
  admin
  user
  guide
  temple
}

enum Trip_type {
  daft
  post
}
